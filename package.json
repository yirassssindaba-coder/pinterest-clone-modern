{
  "name": "pinterest-clone-modern",
  "version": "1.0.0",
  "description": "Pinterest Clone \u2014 TypeScript + Express + Postgres (Drizzle ORM).",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch server/index.ts",
